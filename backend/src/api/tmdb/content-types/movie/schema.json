{
  "kind": "collectionType",
  "collectionName": "movie",
  "info": {
    "singularName": "movie",
    "pluralName": "movies",
    "displayName": "Movie"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "string"
    },
    "release_date": {
      "type": "date"
    },
    "realisator": {
      "type": "string"
    },
    "actors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tmdb.actor",
      "mappedBy": "associated_movies"
    },
    "tmdb_id": {
      "type": "integer",
      "unique": true
    }
  }
}

