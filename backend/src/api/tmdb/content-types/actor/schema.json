{
  "kind": "collectionType",
  "collectionName": "actors",
  "info": {
    "singularName": "actor",
    "pluralName": "actors",
    "displayName": "Actor"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "full_name": {
      "type": "string",
      "required": true
    },

    "name": {
      "type": "string",
      "required": true
    },
    "last_name": {
      "type": "string",
      "required": false
    },
    "tmdb_actor_id": {
      "type": "integer",
      "required": true,
      "unique": true
    },
    "birth_date": {
      "type": "string",
      "required": false
    },
    "associated_movies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tmdb.movie",
      "inversedBy": "actors"
    }
  }
}